          "name": "Geozo"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE teasers SET\n  title = '{{ $json.new_title.replace(/'/g, \"''\") }}',\n  ban_reason = '{{ $json.ban_reason.replace(/'/g, \"''\") }}',\n  remoderation_attempts = remoderation_attempts + 1,\n  status = 'remoderation',\n  updated_at = NOW()\nWHERE ad_id = {{ $json.ad_id }};",
        "options": {}
      },
      "id": "update-db",
      "name": "Update DB Record",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1760,
        0
      ],
      "credentials": {
        "postgres": {
          "id": "postgres-cred",
          "name": "PostgreSQL"
        }
      }
    },
    {
      "parameters": {
        "chatId": "591828204",
        "text": "=\ud83d\udd04 REMODERATION\n\nAd #{{ $json.ad_id }}\nBan reason: {{ $json.ban_reason }}\nOld title: {{ $json.old_title }}\nNew title: {{ $json.new_title }}\n\nSent for remoderation.",
        "additionalFields": {}
      },
      "id": "notify-telegram",
