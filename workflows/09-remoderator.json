        "url": "=https://api.geozo.com/v1/advertiser/ad_groups/{{ $json.ad_group_id }}/ads/remoderate/{{ $json.ad_id }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "send-remoderation",
      "name": "Send for Remoderation",
