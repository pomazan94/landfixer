    {
      "parameters": {
        "jsCode": "const pct = Number($input.first().json.query?.pct || $input.first().json.body?.pct || 10);\nconst factor = (100 - pct) / 100;\n\nreturn [{ json: { pct, factor, action: 'lower_all_bids' } }];"
      },
      "id": "calc-lower-pct",
      "name": "Parse Lower Percentage",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [300, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.geozo.com/v1/advertiser/ads/all",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "filters[status_id_in][]", "value": "5" },
            { "name": "count", "value": "500" }
          ]
        },
        "options": { "response": { "response": { "responseFormat": "json" } } }
      },
      "id": "fetch-active-lower",
      "name": "Fetch Active Ads",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [550, 400],
      "credentials": {
        "httpHeaderAuth": {
          "id": "o0swcMSqweTNOUhw",
          "name": "Geozo"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const factor = $('Parse Lower Percentage').first().json.factor;\nconst pct = $('Parse Lower Percentage').first().json.pct;\nconst adsRaw = $('Fetch Active Ads').first().json;\nconst ads = adsRaw?.data?.result?.data || adsRaw?.data || (Array.isArray(adsRaw) ? adsRaw : []);\n\nif (!Array.isArray(ads) || ads.length === 0) {\n  return [{ json: { action: 'SKIP', reason: 'No active ads', count: 0, pct } }];\n}\n\nconst updates = [];\nads.forEach(ad => {\n  let currentBid = 0;\n  if (ad.bids && Array.isArray(ad.bids)) {\n    const extract = (node) => {\n      if (node.bid) currentBid = currentBid || Number(node.bid);\n      const children = node.children ? (Array.isArray(node.children) ? node.children : Object.values(node.children)) : [];\n      children.forEach(c => extract(c));\n    };\n    ad.bids.forEach(b => extract(b));\n  }\n  if (currentBid > 0) {\n    const newBid = Math.max(0.01, Math.round(currentBid * factor * 10000) / 10000);\n    if (newBid !== currentBid) {\n      updates.push({ ad_id: ad.id, old_bid: currentBid, new_bid: newBid });\n    }\n  }\n});\n\nreturn updates.map(u => ({ json: u }));"
      },
      "id": "calc-new-bids",
      "name": "Calculate New Bids",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [800, 400]
