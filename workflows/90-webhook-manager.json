      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO emergency_state (is_active, trigger_reason, triggered_by, activated_at, auto_deactivate_at)\nVALUES (TRUE, 'Manual emergency stop via webhook', 'webhook_manager', NOW(), NOW() + INTERVAL '2 hours')\nON CONFLICT (is_active) WHERE is_active = TRUE\nDO UPDATE SET trigger_reason = 'Manual emergency stop via webhook', activated_at = NOW(), auto_deactivate_at = NOW() + INTERVAL '2 hours';\n\nUPDATE teasers SET state = 'stopped', state_changed_at = NOW(), state_reason = 'Emergency stop via webhook' WHERE state = 'active';",
        "options": {}
