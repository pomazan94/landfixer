    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT json_build_object(\n  'balance', (SELECT balance FROM balance_history ORDER BY collected_at DESC LIMIT 1),\n  'spend_today', (SELECT COALESCE(SUM(money), 0) FROM ad_stats WHERE date = CURRENT_DATE),\n  'daily_budget', 200,\n  'emergency', (SELECT COALESCE((SELECT json_build_object('active', is_active, 'reason', trigger_reason, 'since', activated_at) FROM emergency_state WHERE is_active = TRUE LIMIT 1), '{\"active\": false}'::json)),\n  'teasers', json_build_object(\n    'active', (SELECT COUNT(*) FROM teasers WHERE state = 'active'),\n    'paused', (SELECT COUNT(*) FROM teasers WHERE state LIKE 'paused_%'),\n    'stopped', (SELECT COUNT(*) FROM teasers WHERE state = 'stopped'),\n    'testing', (SELECT COUNT(*) FROM teasers WHERE state = 'testing'),\n    'recovery', (SELECT COUNT(*) FROM teasers WHERE state = 'recovery_queue')\n  ),\n  'anomalies_unresolved', (SELECT COUNT(*) FROM anomalies WHERE resolved = FALSE),\n  'bid_changes_24h', (SELECT COUNT(*) FROM bid_history WHERE changed_at > NOW() - INTERVAL '24 hours'),\n  'locks', (SELECT COALESCE(json_agg(json_build_object('name', lock_name, 'by', locked_by, 'expires', expires_at)), '[]'::json) FROM workflow_locks WHERE expires_at > NOW())\n) AS status;",
        "options": {}
      },
