      "id": "fetch-geo-stats",
      "name": "Fetch Geo Stats",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        200
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "o0swcMSqweTNOUhw",
          "name": "Geozo"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const statsRaw = $('Fetch Daily Stats').first().json;\nconst balanceRaw = $('Fetch Balance').first().json;\nconst geoRaw = $('Fetch Geo Stats').first().json;\n\nconst stats = statsRaw?.data?.result?.data || statsRaw?.data || (Array.isArray(statsRaw) ? statsRaw : []);\nconst balance = Number(balanceRaw?.data?.balance || balanceRaw?.balance || 0);\nconst geoStats = geoRaw?.data?.result?.data || geoRaw?.data || (Array.isArray(geoRaw) ? geoRaw : []);\n\nlet totalSpend = 0, totalRevenue = 0, totalClicks = 0, totalShows = 0;\nconst adPerformance = [];\n\nif (Array.isArray(stats)) {\n  stats.forEach(s => {\n    const spend = Number(s.money) || 0;\n    const revenue = Number(s.postbacks_confirmed_money) || 0;\n    const clicks = Number(s.clicks_count) || 0;\n    const shows = Number(s.shows_count) || 0;\n    const roi = spend > 0 ? ((revenue - spend) / spend * 100) : 0;\n\n    totalSpend += spend;\n    totalRevenue += revenue;\n    totalClicks += clicks;\n    totalShows += shows;\n\n    adPerformance.push({ ad_id: s.ad_id, spend, revenue, roi, clicks });\n  });\n}\n\n// Sort by ROI\nadPerformance.sort((a, b) => b.roi - a.roi);\n\nconst totalRoi = totalSpend > 0 ? ((totalRevenue - totalSpend) / totalSpend * 100) : 0;\nconst totalProfit = totalRevenue - totalSpend;\n\n// Best and worst\nconst top5 = adPerformance.filter(a => a.roi > 0).slice(0, 5);\nconst worst5 = adPerformance.filter(a => a.roi < 0 && a.spend > 0).slice(-5).reverse();\n\n// Geo breakdown\nconst geoBreakdown = [];\nif (Array.isArray(geoStats)) {\n  geoStats.forEach(g => {\n    const spend = Number(g.money) || 0;\n    const revenue = Number(g.postbacks_confirmed_money) || 0;\n    const roi = spend > 0 ? ((revenue - spend) / spend * 100) : 0;\n    geoBreakdown.push({ country: g.country_code, spend, revenue, roi: Math.round(roi) });\n  });\n  geoBreakdown.sort((a, b) => b.roi - a.roi);\n}\n\n// Count from DB (approximation from stats)\nconst activeAds = adPerformance.filter(a => a.clicks > 0).length;\n\nreturn [{\n  json: {\n    date: $now.format('yyyy-MM-dd'),\n    balance: Math.round(balance * 100) / 100,\n    total_spend: Math.round(totalSpend * 100) / 100,\n    total_revenue: Math.round(totalRevenue * 100) / 100,\n    total_profit: Math.round(totalProfit * 100) / 100,\n    total_roi: Math.round(totalRoi * 100) / 100,\n    total_clicks: totalClicks,\n    total_shows: totalShows,\n    active_ads: activeAds,\n    top5: top5,\n    worst5: worst5,\n    geo_breakdown: geoBreakdown.slice(0, 10)\n  }\n}];"
      },
      "id": "compile-report",
      "name": "Compile Report Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
