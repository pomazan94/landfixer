    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-20250514\",\n  \"max_tokens\": 1024,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"\u0421\u043e\u0441\u0442\u0430\u0432\u044c \u043a\u0440\u0430\u0442\u043a\u0438\u0439 \u0434\u043d\u0435\u0432\u043d\u043e\u0439 \u043e\u0442\u0447\u0451\u0442 \u043c\u0435\u0434\u0438\u0430\u0431\u0430\u0439\u0435\u0440\u0430 \u043d\u0430 \u043e\u0441\u043d\u043e\u0432\u0435 \u0434\u0430\u043d\u043d\u044b\u0445. \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439 \u044d\u043c\u043e\u0434\u0437\u0438. \u0412\u044b\u0434\u0435\u043b\u0438 \u043a\u043b\u044e\u0447\u0435\u0432\u044b\u0435 \u0438\u043d\u0441\u0430\u0439\u0442\u044b \u0438 \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0430\u0446\u0438\u0438 \u043d\u0430 \u0437\u0430\u0432\u0442\u0440\u0430.\\n\\n\u0414\u0430\u043d\u043d\u044b\u0435 \u0437\u0430 {{ $json.date }}:\\n- \u0411\u0430\u043b\u0430\u043d\u0441: ${{ $json.balance }}\\n- \u0420\u0430\u0441\u0445\u043e\u0434: ${{ $json.total_spend }}\\n- \u0414\u043e\u0445\u043e\u0434: ${{ $json.total_revenue }}\\n- \u041f\u0440\u043e\u0444\u0438\u0442: ${{ $json.total_profit }}\\n- ROI: {{ $json.total_roi }}%\\n- \u041a\u043b\u0438\u043a\u0438: {{ $json.total_clicks }}\\n- \u041f\u043e\u043a\u0430\u0437\u044b: {{ $json.total_shows }}\\n- \u0410\u043a\u0442\u0438\u0432\u043d\u044b\u0445 \u043e\u0431\u044a\u044f\u0432\u043b\u0435\u043d\u0438\u0439: {{ $json.active_ads }}\\n\\n\u0422\u043e\u043f-5 \u043f\u0440\u043e\u0444\u0438\u0442\u043d\u044b\u0445:\\n{{ $json.top5.map(a => `Ad #${a.ad_id}: ROI ${a.roi.toFixed(1)}%, Profit $${(a.revenue-a.spend).toFixed(2)}`).join('\\n') }}\\n\\n\u0422\u043e\u043f-5 \u0443\u0431\u044b\u0442\u043e\u0447\u043d\u044b\u0445:\\n{{ $json.worst5.map(a => `Ad #${a.ad_id}: ROI ${a.roi.toFixed(1)}%, Loss $${(a.spend-a.revenue).toFixed(2)}`).join('\\n') }}\\n\\n\u0413\u0435\u043e:\\n{{ $json.geo_breakdown.map(g => `${g.country}: ROI ${g.roi}%, Spend $${g.spend.toFixed(2)}`).join('\\n') }}\\n\\n\u0424\u043e\u0440\u043c\u0430\u0442: \u0442\u0435\u043a\u0441\u0442 \u0434\u043b\u044f Telegram (\u0431\u0435\u0437 markdown, \u043c\u0430\u043a\u0441\u0438\u043c\u0443\u043c 3000 \u0441\u0438\u043c\u0432\u043e\u043b\u043e\u0432).\"\n    }\n  ]\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "generate-report",
      "name": "Generate Report (Claude)",
