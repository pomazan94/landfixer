# --- n8n ---
N8N_USER=admin
N8N_PASSWORD=changeme
N8N_HOST=bot.lead-collector.pro
WEBHOOK_URL=https://bot.lead-collector.pro/

# --- PostgreSQL ---
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_secret

# --- Redis ---
REDIS_PASSWORD=redis_secret

# --- Geozo API ---
GEOZO_API_BASE_URL=https://api.geozo.com/v1
GEOZO_API_TOKEN=your_geozo_private_token_here

# --- Claude API ---
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Image Generation ---
IMAGE_GEN_API=stable-diffusion
STABLE_DIFFUSION_API_URL=http://localhost:7860
OPENAI_API_KEY=your_openai_key_for_dalle

# --- DataImpulse Proxy ---
# Настраивается через Admin UI → Конфиг → proxy
# (login, password, host, port хранятся в bot_config)

# --- General ---
TIMEZONE=Europe/Moscow
DEFAULT_BID=0.01
MAX_BID_CEILING=0.10
DAILY_BUDGET_LIMIT=50
MIN_BALANCE_ALERT=10
