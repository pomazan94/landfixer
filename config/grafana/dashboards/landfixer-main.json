{
  "uid": "landfixer-main",
  "title": "LandFixer - Main Dashboard",
  "tags": ["landfixer", "geozo"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Emergency Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT CASE WHEN is_active THEN 'EMERGENCY ACTIVE' ELSE 'Normal' END AS \"status\" FROM emergency_state WHERE is_active = TRUE UNION ALL SELECT 'Normal' LIMIT 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "EMERGENCY ACTIVE": { "color": "red", "text": "EMERGENCY" } } },
            { "type": "value", "options": { "Normal": { "color": "green", "text": "OK" } } }
          ],
          "thresholds": { "steps": [{ "value": null, "color": "green" }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Current Balance",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT balance AS \"Balance\" FROM balance_history ORDER BY collected_at DESC LIMIT 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 20, "color": "yellow" },
              { "value": 100, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Today Spend / Budget",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(SUM(money), 0) AS \"Spend\" FROM ad_stats WHERE date = CURRENT_DATE;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "min": 0,
          "max": 200,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 160, "color": "yellow" },
              { "value": 190, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Ads Today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT ad_id) AS \"Ads\" FROM ad_stats WHERE date = CURRENT_DATE;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "value": null, "color": "blue" }] }
        }
      }
    },
    {
      "id": 5,
      "title": "Total Clicks Today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(SUM(clicks), 0) AS \"Clicks\" FROM ad_stats WHERE date = CURRENT_DATE;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "value": null, "color": "purple" }] }
        }
      }
    },
    {
      "id": 6,
      "title": "Avg CTR Today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG(ctr)::numeric, 2) AS \"CTR %\" FROM ad_stats WHERE date = CURRENT_DATE AND shows > 100;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "yellow" },
              { "value": 2, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Balance Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT collected_at AS time, balance AS \"Balance\", spend_rate_per_hour AS \"Spend Rate $/h\" FROM balance_history WHERE $__timeFilter(collected_at) ORDER BY collected_at;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 11,
      "title": "Spend by Ad (Today)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT ad_id::text AS \"Ad ID\", money AS \"Spend\", clicks AS \"Clicks\" FROM ad_stats WHERE date = CURRENT_DATE AND money > 0 ORDER BY money DESC LIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "color": { "mode": "palette-classic" } }
      },
      "options": {
        "xField": "Ad ID"
      }
    },
    {
      "id": 20,
      "title": "Spend by Hour (Today)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT EXTRACT(HOUR FROM collected_at)::int AS \"Hour\", SUM(money) AS \"Spend\" FROM ad_stats WHERE date = CURRENT_DATE GROUP BY EXTRACT(HOUR FROM collected_at) ORDER BY \"Hour\";",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "color": { "mode": "palette-classic" } } },
      "options": { "xField": "Hour" }
    },
    {
      "id": 21,
      "title": "CTR vs CPC by Ad (Today)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT ad_id::text AS \"Ad ID\", ctr AS \"CTR %\", cpc AS \"CPC $\" FROM ad_stats WHERE date = CURRENT_DATE AND shows > 100 ORDER BY ctr DESC LIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": { "xField": "Ad ID" }
    },
    {
      "id": 30,
      "title": "All Ads - Today Stats",
      "type": "table",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT ad_id AS \"Ad ID\", shows AS \"Shows\", confirmed_shows AS \"Confirmed\", clicks AS \"Clicks\", ROUND(ctr::numeric, 2) AS \"CTR %\", ROUND(cpc::numeric, 4) AS \"CPC $\", ROUND(money::numeric, 2) AS \"Spend $\", postbacks_count AS \"Leads\", ROUND(postbacks_confirmed_money::numeric, 2) AS \"Revenue $\", ROUND(roi::numeric, 1) AS \"ROI %\", ROUND(profit::numeric, 2) AS \"Profit $\", collected_at AS \"Updated\" FROM ad_stats WHERE date = CURRENT_DATE ORDER BY money DESC;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Spend $" }, "properties": [{ "id": "unit", "value": "currencyUSD" }] },
          { "matcher": { "id": "byName", "options": "Revenue $" }, "properties": [{ "id": "unit", "value": "currencyUSD" }] },
          { "matcher": { "id": "byName", "options": "Profit $" }, "properties": [{ "id": "unit", "value": "currencyUSD" }] },
          {
            "matcher": { "id": "byName", "options": "ROI %" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 0, "color": "yellow" }, { "value": 20, "color": "green" }] } },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CTR %" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "yellow" }, { "value": 2, "color": "green" }] } },
              { "id": "custom.displayMode", "value": "color-text" }
            ]
          }
        ]
      }
    },
    {
      "id": 31,
      "title": "Daily Spend vs Revenue (History)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT date AS time, total_spend AS \"Spend\", total_revenue AS \"Revenue\", gross_profit AS \"Profit\" FROM daily_pnl WHERE date >= CURRENT_DATE - INTERVAL '30 days' ORDER BY date;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Profit" }, "properties": [{ "id": "custom.fillOpacity", "value": 20 }] }
        ]
      }
    },
    {
      "id": 40,
      "title": "Bid History (24h)",
      "type": "table",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 40 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT bh.changed_at AS \"Time\", bh.ad_id AS \"Ad ID\", bh.old_bid AS \"Old Bid\", bh.new_bid AS \"New Bid\", ROUND(CASE WHEN bh.old_bid > 0 THEN (bh.new_bid - bh.old_bid) / bh.old_bid * 100 ELSE 0 END, 1) AS \"Change %\", bh.rule_applied AS \"Rule\", bh.reason AS \"Reason\" FROM bid_history bh WHERE bh.changed_at > NOW() - INTERVAL '24 hours' ORDER BY bh.changed_at DESC LIMIT 50;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Old Bid" }, "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 4 }] },
          { "matcher": { "id": "byName", "options": "New Bid" }, "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 4 }] },
          { "matcher": { "id": "byName", "options": "Change %" }, "properties": [{ "id": "thresholds", "value": { "steps": [{ "value": null, "color": "red" }, { "value": 0, "color": "green" }] } }, { "id": "custom.displayMode", "value": "color-text" }] }
        ]
      }
    },
    {
      "id": 41,
      "title": "Anomalies",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 40 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "dff2mshnmups0f" },
      "targets": [
        {
          "rawSql": "SELECT detected_at AS \"Detected\", ad_id AS \"Ad ID\", anomaly_type AS \"Type\", severity AS \"Severity\", SUBSTRING(description FROM 1 FOR 100) AS \"Description\" FROM anomalies WHERE resolved = FALSE ORDER BY detected_at DESC LIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Severity" }, "properties": [{ "id": "mappings", "value": [{ "type": "value", "options": { "critical": { "color": "red" }, "warning": { "color": "orange" }, "info": { "color": "blue" } } }] }, { "id": "custom.displayMode", "value": "color-background" }] }
        ]
      }
    },
    {
      "id": 60,
      "title": "Management Actions",
      "type": "text",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 48 },
      "options": {
        "mode": "html",
        "content": "<div style=\"font-family: monospace; padding: 16px;\">\n<h3>Quick Actions (via n8n webhooks)</h3>\n<table style=\"width: 100%; border-collapse: collapse;\">\n<tr style=\"border-bottom: 1px solid #555;\">\n<td style=\"padding: 8px;\"><strong>Emergency STOP</strong></td>\n<td><code>curl -X POST https://bot.lead-collector.pro/webhook/emergency-stop</code></td>\n</tr>\n<tr style=\"border-bottom: 1px solid #555;\">\n<td style=\"padding: 8px;\"><strong>Clear emergency</strong></td>\n<td><code>curl -X POST https://bot.lead-collector.pro/webhook/emergency-clear</code></td>\n</tr>\n<tr style=\"border-bottom: 1px solid #555;\">\n<td style=\"padding: 8px;\"><strong>Lower all bids 10%</strong></td>\n<td><code>curl -X POST https://bot.lead-collector.pro/webhook/lower-all-bids?pct=10</code></td>\n</tr>\n<tr style=\"border-bottom: 1px solid #555;\">\n<td style=\"padding: 8px;\"><strong>System status</strong></td>\n<td><code>curl https://bot.lead-collector.pro/webhook/status</code></td>\n</tr>\n</table>\n</div>"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
