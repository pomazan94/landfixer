{
  "uid": "landfixer-main",
  "title": "LandFixer - Main Dashboard",
  "tags": ["landfixer", "geozo"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "n8n_url",
        "type": "constant",
        "query": "http://n8n:5678",
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Emergency Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT CASE WHEN is_active THEN 'EMERGENCY ACTIVE' ELSE 'Normal' END AS \"status\" FROM emergency_state WHERE is_active = TRUE UNION ALL SELECT 'Normal' LIMIT 1;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "EMERGENCY ACTIVE": { "color": "red", "text": "EMERGENCY" } } },
            { "type": "value", "options": { "Normal": { "color": "green", "text": "OK" } } }
          ],
          "thresholds": { "steps": [{ "value": null, "color": "green" }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Current Balance",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT balance AS \"Balance\" FROM balance_history ORDER BY collected_at DESC LIMIT 1;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 20, "color": "yellow" },
              { "value": 100, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Today Spend / Budget",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT COALESCE(SUM(money), 0) AS \"Spend\" FROM ad_stats WHERE date = CURRENT_DATE;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "min": 0,
          "max": 200,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 160, "color": "yellow" },
              { "value": 190, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Teasers by State",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT state, COUNT(*) AS count FROM teasers WHERE ad_id IS NOT NULL GROUP BY state ORDER BY count DESC;",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Anomalies",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Anomalies\" FROM anomalies WHERE resolved = FALSE;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 3, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Bid Changes (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Changes\" FROM bid_history WHERE changed_at > NOW() - INTERVAL '24 hours';",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 100, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Balance Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT collected_at AS time, balance AS \"Balance\", spend_rate_per_hour AS \"Spend Rate $/h\" FROM balance_history WHERE $__timeFilter(collected_at) ORDER BY collected_at;",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 11,
      "title": "Daily Spend vs Revenue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT date AS time, total_spend AS \"Spend\", total_revenue AS \"Revenue\", gross_profit AS \"Profit\" FROM daily_pnl WHERE date >= CURRENT_DATE - INTERVAL '30 days' ORDER BY date;",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Profit" }, "properties": [{ "id": "custom.fillOpacity", "value": 20 }] }
        ]
      }
    },
    {
      "id": 20,
      "title": "Spend by Hour (Today)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT EXTRACT(HOUR FROM collected_at)::int AS \"Hour\", SUM(money) AS \"Spend\" FROM ad_stats WHERE date = CURRENT_DATE GROUP BY EXTRACT(HOUR FROM collected_at) ORDER BY \"Hour\";",
          "format": "table"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 21,
      "title": "ROI by Geo (7 days)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT gp.country_code || ' ' || gp.country_name AS \"Geo\", ROUND(CASE WHEN SUM(gs.money) > 0 THEN (SUM(gs.postbacks_confirmed_money) - SUM(gs.money)) / SUM(gs.money) * 100 ELSE 0 END, 1) AS \"ROI %\", ROUND(SUM(gs.money)::numeric, 2) AS \"Spend\" FROM geo_stats gs JOIN geo_payouts gp ON gp.country_code = gs.country_code WHERE gs.date >= CURRENT_DATE - INTERVAL '7 days' GROUP BY gp.country_code, gp.country_name HAVING SUM(gs.money) > 1 ORDER BY \"ROI %\" DESC;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "ROI %" }, "properties": [{ "id": "thresholds", "value": { "steps": [{ "value": null, "color": "red" }, { "value": 0, "color": "yellow" }, { "value": 20, "color": "green" }] } }] }
        ]
      }
    },
    {
      "id": 30,
      "title": "Active Teasers",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT t.ad_id AS \"Ad ID\", t.title AS \"Title\", t.state AS \"State\", t.bid AS \"Bid\", t.escalation_level AS \"Esc Lvl\", t.bid_changes_today AS \"Bid Changes\", COALESCE(s.money, 0) AS \"Spend Today\", COALESCE(s.clicks, 0) AS \"Clicks\", COALESCE(s.ctr, 0) AS \"CTR %\", COALESCE(s.roi, 0) AS \"ROI %\", t.state_reason AS \"Reason\", t.state_changed_at AS \"State Since\" FROM teasers t LEFT JOIN ad_stats s ON s.ad_id = t.ad_id AND s.date = CURRENT_DATE WHERE t.ad_id IS NOT NULL ORDER BY s.money DESC NULLS LAST LIMIT 100;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Bid" }, "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 4 }] },
          { "matcher": { "id": "byName", "options": "Spend Today" }, "properties": [{ "id": "unit", "value": "currencyUSD" }] },
          { "matcher": { "id": "byName", "options": "ROI %" }, "properties": [{ "id": "thresholds", "value": { "steps": [{ "value": null, "color": "red" }, { "value": 0, "color": "yellow" }, { "value": 20, "color": "green" }] } }, { "id": "custom.displayMode", "value": "color-background" }] },
          { "matcher": { "id": "byName", "options": "State" }, "properties": [{ "id": "mappings", "value": [{ "type": "value", "options": { "active": { "color": "green" }, "testing": { "color": "blue" }, "stopped": { "color": "red" }, "paused_high_cpl": { "color": "orange" }, "paused_budget": { "color": "yellow" }, "recovery_queue": { "color": "purple" } } }] }, { "id": "custom.displayMode", "value": "color-background" }] }
        ]
      }
    },
    {
      "id": 40,
      "title": "Bid History (24h)",
      "type": "table",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 30 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT bh.changed_at AS \"Time\", bh.ad_id AS \"Ad ID\", bh.old_bid AS \"Old Bid\", bh.new_bid AS \"New Bid\", ROUND(CASE WHEN bh.old_bid > 0 THEN (bh.new_bid - bh.old_bid) / bh.old_bid * 100 ELSE 0 END, 1) AS \"Change %\", bh.rule_applied AS \"Rule\", bh.reason AS \"Reason\" FROM bid_history bh WHERE bh.changed_at > NOW() - INTERVAL '24 hours' ORDER BY bh.changed_at DESC LIMIT 50;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Old Bid" }, "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 4 }] },
          { "matcher": { "id": "byName", "options": "New Bid" }, "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 4 }] },
          { "matcher": { "id": "byName", "options": "Change %" }, "properties": [{ "id": "thresholds", "value": { "steps": [{ "value": null, "color": "red" }, { "value": 0, "color": "green" }] } }, { "id": "custom.displayMode", "value": "color-text" }] }
        ]
      }
    },
    {
      "id": 41,
      "title": "State Transitions (24h)",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 30 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT created_at AS \"Time\", ad_id AS \"Ad ID\", old_state AS \"From\", new_state AS \"To\", triggered_by AS \"By\", SUBSTRING(reason FROM 1 FOR 80) AS \"Reason\" FROM teaser_state_log WHERE created_at > NOW() - INTERVAL '24 hours' ORDER BY created_at DESC LIMIT 30;",
          "format": "table"
        }
      ]
    },
    {
      "id": 50,
      "title": "Workflow Locks",
      "type": "table",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 38 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT lock_name AS \"Lock\", locked_by AS \"Held By\", locked_at AS \"Since\", expires_at AS \"Expires\", CASE WHEN expires_at < NOW() THEN 'EXPIRED' ELSE 'ACTIVE' END AS \"Status\" FROM workflow_locks ORDER BY locked_at DESC;",
          "format": "table"
        }
      ]
    },
    {
      "id": 51,
      "title": "Anomalies (Unresolved)",
      "type": "table",
      "gridPos": { "h": 4, "w": 16, "x": 8, "y": 38 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT detected_at AS \"Detected\", ad_id AS \"Ad ID\", anomaly_type AS \"Type\", severity AS \"Severity\", SUBSTRING(description FROM 1 FOR 100) AS \"Description\", deviation_percent AS \"Deviation %\" FROM anomalies WHERE resolved = FALSE ORDER BY detected_at DESC LIMIT 20;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Severity" }, "properties": [{ "id": "mappings", "value": [{ "type": "value", "options": { "critical": { "color": "red" }, "warning": { "color": "orange" }, "info": { "color": "blue" } } }] }, { "id": "custom.displayMode", "value": "color-background" }] }
        ]
      }
    },
    {
      "id": 60,
      "title": "Management Actions",
      "type": "text",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 42 },
      "options": {
        "mode": "html",
        "content": "<div style=\"font-family: monospace; padding: 16px;\">\n<h3>Quick Actions (via n8n webhooks)</h3>\n<p>Use these URLs to trigger management actions. Replace <code>YOUR_N8N_HOST</code> with your actual n8n host.</p>\n<table style=\"width: 100%; border-collapse: collapse;\">\n<tr style=\"border-bottom: 1px solid #333;\">\n<td style=\"padding: 8px;\"><strong>Emergency STOP all ads</strong></td>\n<td><code>POST http://YOUR_N8N_HOST:5678/webhook/emergency-stop</code></td>\n</tr>\n<tr style=\"border-bottom: 1px solid #333;\">\n<td style=\"padding: 8px;\"><strong>Deactivate emergency</strong></td>\n<td><code>POST http://YOUR_N8N_HOST:5678/webhook/emergency-clear</code></td>\n</tr>\n<tr style=\"border-bottom: 1px solid #333;\">\n<td style=\"padding: 8px;\"><strong>Lower all bids by 10%</strong></td>\n<td><code>POST http://YOUR_N8N_HOST:5678/webhook/lower-all-bids?pct=10</code></td>\n</tr>\n<tr style=\"border-bottom: 1px solid #333;\">\n<td style=\"padding: 8px;\"><strong>Resume paused teaser</strong></td>\n<td><code>POST http://YOUR_N8N_HOST:5678/webhook/resume-teaser?ad_id=12345</code></td>\n</tr>\n<tr style=\"border-bottom: 1px solid #333;\">\n<td style=\"padding: 8px;\"><strong>System status</strong></td>\n<td><code>GET http://YOUR_N8N_HOST:5678/webhook/status</code></td>\n</tr>\n</table>\n</div>"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
